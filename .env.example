# Copie este arquivo para ".env" e preencha os valores reais (uso local/Railway).
# NUNCA suba o arquivo ".env" de verdade para o GitHub.

# ---------- Usadas pelo server.js (Railway / local) ----------

# Chave da API da Groq (usada primeiro, se preenchida — texto gerado por Llama).
# Pegue a sua em https://console.groq.com
GROQ_API_KEY=

# Chave da API da Anthropic (usada se a Groq não estiver configurada ou falhar).
# Se ambas ficarem em branco, o sistema usa um texto padrão automático (fallback).
ANTHROPIC_API_KEY=

# Porta em que o servidor vai rodar. O Railway define isso automaticamente
# em produção (você pode deixar 8080 mesmo assim, é só o padrão local).
PORT=8080

# ---------- NÃO usadas pelo server.js — só pelo script do GitHub Actions ----------
# Estas NÃO devem ir no .env do Railway. Configure-as como "Secrets" no
# repositório do GitHub (Settings > Secrets and variables > Actions):
#
#   FIREBASE_SERVICE_ACCOUNT   -> JSON completo da service account do Firebase
#                                 (Firebase Console > Configurações do projeto >
#                                 Contas de serviço > Gerar nova chave privada)
#   OWNER_UID                  -> o UID do seu usuário logado (aparece na aba
#                                 "Perfil de Afiliado" do painel depois do login)
#   GROQ_API_KEY / ANTHROPIC_API_KEY -> opcionais, mesmas chaves acima, se quiser
#                                 que o bot automático também gere a copy de venda
#   MIN_DESCONTO_PCT           -> desconto mínimo (%) pra uma oferta ser aprovada (padrão 25)
#   MIN_COMISSAO_PCT           -> comissão mínima (%) pra uma oferta ser aprovada (padrão 7)
